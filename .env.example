# =============================================================================
# Python pipeline (main.py, data collection)
# Copy this file to `.env` in the project root and fill in your key.
# =============================================================================

# Amap (Gaode) Web Service API key — https://lbs.amap.com/
# Used by Python data pipeline, dev/preview transit API, and Netlify Functions (transit planner).
# Netlify: Site settings → Environment variables → AMAP_KEY (not VITE_ — server-side only).
AMAP_KEY=

# Anjuke browser cookie for listing refresh (scripts/refresh_anjuke_listings.py, GitHub Actions)
# Paste the full cookie header from gz.zu.anjuke.com — expires frequently.
# If the value contains '=', wrap the whole cookie in double quotes:
# ANJUKE_COOKIE="id58=...; aQQ_ajk-appId=...; ..."
# Or save the raw cookie (one line) to data/anjuke_cookie.txt (gitignored) instead:
# ANJUKE_COOKIE_FILE=data/anjuke_cookie.txt

# Email notifications (refresh start / success / crash — local + GitHub Actions)
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords)
# NOTIFY_EMAIL=you@gmail.com
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# GUAMAP_MAX_AUTO_RETRIES=20   # auto-retry cap (Continue Anjuke refresh workflow)
# GUAMAP_CHECKPOINT_EVERY=10   # local disk checkpoint interval (communities/blocks)

# Supabase service role — used by scrape pipeline to tag off-market saved favourites (never expose in frontend)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# =============================================================================
# Frontend (Vite — Mapbox, Supabase)
# Copy these lines to `frontend/.env.local` (create the file if needed).
# Restart `npm run dev` after changing env vars.
# =============================================================================

# Mapbox public access token (starts with pk.) — https://account.mapbox.com/access-tokens/
# Use a URL-restricted token before deploying to production.
VITE_MAPBOX_ACCESS_TOKEN=

# Supabase (optional — saved listings sync)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
